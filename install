#!/bin/bash
export DOTSPATH="$HOME/dotfiles"

function update_or_download() {
  if [ -e $DOTSPATH/.git ]; then
    git -C "$DOTSPATH" pull
  else
    git clone https://github.com/AlessioCoser/dotfiles.git "$DOTSPATH"
  fi
}

# `configs` runs all scripts but skips package installation
# (for standard users on machines where software is already installed by an admin)
if [ "$1" = "configs" ]; then
  export CONFIGS_ONLY=1
  set --
fi

# skip git pull when running a single script (assume local development)
[ -z "$1" ] && update_or_download

. $DOTSPATH/lib/execute_os_scripts
execute_os_scripts "$1"